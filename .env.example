# Copiar a .env.local y completar (no commitear secretos).

# Firebase (cliente)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_APP_URL=http://localhost:9003

# --- NotificasHub (WhatsApp) ---
# Mismo valor que internalSecret del tenant Firestore tenants/regatas en NotificasHub.
# El servidor usa estas vars para: enviar mensajes, webhook entrante y registrar teléfonos:
#   POST|DELETE {NOTIFICASHUB_URL}/api/register-user  (header x-internal-secret, body { phone, tenantId: regatas }).
NOTIFICASHUB_INTERNAL_SECRET=
# URL base sin barra final (ej. https://notificashub--TU_PROJECT.us-east4.hosted.app)
NOTIFICASHUB_URL=https://notificashub.com
NEXT_PUBLIC_NOTIFICASHUB_ACTIVO=true

# ID del tenant en Firestore del hub (tenants/{id}); debe coincidir con register-user y con el webhook.
# Por defecto: regatas. Si el hub usa otro string, setearlo acá y en App Hosting.
# NOTIFICASHUB_TENANT_ID=regatas
# Alias soportado: NOTIFICASHUB_DEFAULT_TENANT_ID

# Firestore de NotificasHub (user_memberships) — proyecto distinto a la app (Cloud Functions):
# NOTIFICASHUB_CREDENTIALS_PATH=./ruta/al-service-account.json
# NOTIFICASHUB_FIREBASE_PROJECT_ID=
# NOTIFICASHUB_FIREBASE_CLIENT_EMAIL=
# NOTIFICASHUB_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Cuenta de servicio Regatas (firebase-admin: API routes locales)
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# QR Regatas+ (JWT para validación de socios en comercios); mínimo 32 caracteres para HS256
QR_JWT_SECRET=cambiar_por_secreto_seguro_de_32_chars_minimo

# Opcional: sesión del portal /entradas-abonado (si no se define, se reutiliza QR_JWT_SECRET)
# ENTRADAS_ABONADO_JWT_SECRET=

# Club
NEXT_PUBLIC_CLUB_NOMBRE="Club de Regatas San Nicolás"
NEXT_PUBLIC_CLUB_SLUG="regatas-san-nicolas"

# Banco del club (para transferencias)
CLUB_CBU=0000000000000000000000
CLUB_ALIAS=REGATAS.SN
CLUB_BANCO=Santander
NEXT_PUBLIC_CLUB_WA_NUMBER=5491112345678

# Mercado Pago — vacío hasta tener cuenta
# MP_ACCESS_TOKEN=
# MP_WEBHOOK_SECRET=
MP_ENABLED=false

# Santander Pay — vacío hasta tener API
# SANTANDER_PAY_API_KEY=
SANTANDER_PAY_ENABLED=false

# Viajes - Notificaciones email (opcional)
# SENDGRID_API_KEY=SG....
