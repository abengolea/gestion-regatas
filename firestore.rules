rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isGerenteClub() {
      return isSignedIn() && (
        request.auth.token.email == 'abengolea1@gmail.com'
        || (exists(/databases/$(database)/documents/platformUsers/$(request.auth.uid))
            && (get(/databases/$(database)/documents/platformUsers/$(request.auth.uid)).data.get('gerente_club', false) == true
                || get(/databases/$(database)/documents/platformUsers/$(request.auth.uid)).data.get('super_admin', false) == true))
      );
    }

    function userExistsInSubcomision(subcomisionId) {
      return exists(/databases/$(database)/documents/subcomisiones/$(subcomisionId)/users/$(request.auth.uid))
        || exists(/databases/$(database)/documents/schools/$(subcomisionId)/users/$(request.auth.uid));
    }

    function getSubcomisionUserData(subcomisionId) {
      return userExistsInSubcomision(subcomisionId)
        ? (exists(/databases/$(database)/documents/subcomisiones/$(subcomisionId)/users/$(request.auth.uid))
            ? get(/databases/$(database)/documents/subcomisiones/$(subcomisionId)/users/$(request.auth.uid)).data
            : get(/databases/$(database)/documents/schools/$(subcomisionId)/users/$(request.auth.uid)).data)
        : null;
    }

    function isAdminSubcomision(subcomisionId) {
      let userData = getSubcomisionUserData(subcomisionId);
      return isSignedIn() && userData != null && userData.role == 'admin_subcomision';
    }

    function isEncargadoDeportivo(subcomisionId) {
      let userData = getSubcomisionUserData(subcomisionId);
      return isSignedIn() && userData != null && userData.role == 'encargado_deportivo';
    }

    function isStaffOfSubcomision(subcomisionId) {
      return isGerenteClub()
        || isAdminSubcomision(subcomisionId)
        || isEncargadoDeportivo(subcomisionId);
    }

    function isEditorOrViewer(subcomisionId) {
      let userData = getSubcomisionUserData(subcomisionId);
      return isSignedIn() && userData != null
        && (userData.role == 'editor' || userData.role == 'viewer');
    }

    function canReadInSubcomision(subcomisionId) {
      return isGerenteClub() || isStaffOfSubcomision(subcomisionId) || isEditorOrViewer(subcomisionId);
    }

    // Solo puede tocarse la raíz subcomisiones/{id} desde cliente con mapa ventaAbonoPublica (checkout abonos web).
    function subcomisionVentaAbonoPublicaUpdateOnly(subcomisionId) {
      return isStaffOfSubcomision(subcomisionId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ventaAbonoPublica']);
    }

    function isOwnSocio(subcomisionId, socioId) {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/subcomisiones/$(subcomisionId)/socios/$(socioId))
        && get(/databases/$(database)/documents/subcomisiones/$(subcomisionId)/socios/$(socioId)).data.get('email', '').lower() == request.auth.token.email.lower();
    }

    function hasSocioLoginFor(subcomisionId, socioId) {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/socioLogins/$(request.auth.token.email.lower()))
        && get(/databases/$(database)/documents/socioLogins/$(request.auth.token.email.lower())).data.get('subcomisionId', '') == subcomisionId
        && get(/databases/$(database)/documents/socioLogins/$(request.auth.token.email.lower())).data.get('socioId', '') == socioId;
    }

    function isComercio() {
      return isSignedIn() && exists(/databases/$(database)/documents/comercios/$(request.auth.uid));
    }

    // Auditoría (escritura desde cliente solo gerente; lectura solo gerente)
    match /auditLog/{entryId} {
      allow read: if isGerenteClub();
      allow create: if isGerenteClub();
      allow update, delete: if false;
    }

    // --- Solo para chequeo de gerente_club ---
    // Lectura: gerente o el propio usuario. Escritura: solo el propio usuario puede crear/actualizar su doc.
    // Usuarios normales no pueden ponerse super_admin ni gerente_club.
    match /platformUsers/{userId} {
      allow read: if isSignedIn() && (isGerenteClub() || request.auth.uid == userId);
      // Crear: el propio usuario O un gerente al dar de alta nuevos admins
      allow create: if isSignedIn() && (
        (request.auth.uid == userId && (
          request.auth.token.email == 'abengolea1@gmail.com'
          || (!request.resource.data.get('super_admin', false) && !request.resource.data.get('gerente_club', false))
        ))
        || (isGerenteClub() && !request.resource.data.get('super_admin', false) && !request.resource.data.get('gerente_club', false))
      );
      allow update: if isSignedIn() && request.auth.uid == userId && (
        request.auth.token.email == 'abengolea1@gmail.com'
        || (!request.resource.data.get('super_admin', false) && !request.resource.data.get('gerente_club', false))
      );
      allow delete: if false;
    }

    match /socioLogins/{emailKey} {
      allow read: if isSignedIn() && request.auth.token.email != null && emailKey == request.auth.token.email.lower();
      allow write: if isGerenteClub();
    }

    // --- Reglas principales ---

    // Lectura de la raíz (nombre, moduleFlags, etc.): cualquier rol que ya lee la escuela (incl. editor/viewer).
    // Antes solo staff; SidebarNav y SubcomisionModuleGuard usan useDoc en esta ruta para todos los no–super-admin.
    match /subcomisiones/{subcomisionId} {
      allow read: if isSignedIn() && canReadInSubcomision(subcomisionId);
      allow create: if isGerenteClub();
      allow update: if isGerenteClub() || subcomisionVentaAbonoPublicaUpdateOnly(subcomisionId);
      allow delete: if false;
    }

    match /subcomisiones/{subcomisionId}/users/{userId} {
      allow read: if isSignedIn() && (isGerenteClub() || isStaffOfSubcomision(subcomisionId) || request.auth.uid == userId);
      allow create, update: if isGerenteClub() || isAdminSubcomision(subcomisionId);
      allow delete: if isGerenteClub() || isAdminSubcomision(subcomisionId);
    }

    match /subcomisiones/{subcomisionId}/socios/{socioId} {
      allow read: if isSignedIn() && (
        isGerenteClub()
        || isStaffOfSubcomision(subcomisionId)
        || isEditorOrViewer(subcomisionId)
        || isOwnSocio(subcomisionId, socioId)
        || hasSocioLoginFor(subcomisionId, socioId)
      );
      allow create: if isGerenteClub() || isAdminSubcomision(subcomisionId);
      allow update: if isGerenteClub() || isAdminSubcomision(subcomisionId) || isOwnSocio(subcomisionId, socioId) || hasSocioLoginFor(subcomisionId, socioId);
      allow delete: if isGerenteClub() || isAdminSubcomision(subcomisionId);
    }

    match /subcomisiones/{subcomisionId}/categorias/{categoriaId} {
      allow read, write: if isGerenteClub() || isStaffOfSubcomision(subcomisionId);
    }

    // Venta de entradas / plateas (eventos y plano de asientos; cobro vía API Admin)
    match /subcomisiones/{subcomisionId}/plateasEventos/{eventId} {
      allow read, write: if isGerenteClub() || isStaffOfSubcomision(subcomisionId);
      match /asientos/{asientoId} {
        allow read, write: if isGerenteClub() || isStaffOfSubcomision(subcomisionId);
      }
    }

    // Evaluaciones de socios (los docs usan playerId; legacy puede tener socioId)
    match /subcomisiones/{subcomisionId}/evaluations/{evalId} {
      allow read: if isSignedIn() && (
        canReadInSubcomision(subcomisionId)
        || (resource.data.socioId != null && (isOwnSocio(subcomisionId, resource.data.socioId) || hasSocioLoginFor(subcomisionId, resource.data.socioId)))
        || (resource.data.playerId != null && (isOwnSocio(subcomisionId, resource.data.playerId) || hasSocioLoginFor(subcomisionId, resource.data.playerId)))
      );
      allow create, update: if isStaffOfSubcomision(subcomisionId);
      allow delete: if isStaffOfSubcomision(subcomisionId);
    }

    // Evaluaciones físicas y config
    match /subcomisiones/{subcomisionId}/physicalAssessments/{docId} {
      allow read: if isSignedIn() && (
        canReadInSubcomision(subcomisionId)
        || (resource.data.socioId != null && (isOwnSocio(subcomisionId, resource.data.socioId) || hasSocioLoginFor(subcomisionId, resource.data.socioId)))
        || (resource.data.playerId != null && (isOwnSocio(subcomisionId, resource.data.playerId) || hasSocioLoginFor(subcomisionId, resource.data.playerId)))
      );
      allow create, update: if isStaffOfSubcomision(subcomisionId);
      allow delete: if isStaffOfSubcomision(subcomisionId);
    }
    match /subcomisiones/{subcomisionId}/physicalAssessmentConfig/{docId} {
      allow read: if isSignedIn() && canReadInSubcomision(subcomisionId);
      allow write: if isStaffOfSubcomision(subcomisionId);
    }

    // Videoteca de socios (queries filtran por playerId en varias pantallas)
    match /subcomisiones/{subcomisionId}/socioVideos/{videoId} {
      allow read: if isSignedIn() && (
        canReadInSubcomision(subcomisionId)
        || (resource.data.socioId != null && (isOwnSocio(subcomisionId, resource.data.socioId) || hasSocioLoginFor(subcomisionId, resource.data.socioId)))
        || (resource.data.playerId != null && (isOwnSocio(subcomisionId, resource.data.playerId) || hasSocioLoginFor(subcomisionId, resource.data.playerId)))
      );
      allow create, update, delete: if isStaffOfSubcomision(subcomisionId);
    }

    // Config mensualidad y pagos (staff)
    match /subcomisiones/{subcomisionId}/clubFeeConfig/{docId} {
      allow read, write: if isStaffOfSubcomision(subcomisionId);
    }
    match /subcomisiones/{subcomisionId}/paymentConfig/{docId} {
      allow read, write: if isStaffOfSubcomision(subcomisionId);
    }

    // Horarios de entrenamiento
    match /subcomisiones/{subcomisionId}/trainingConfig/{docId} {
      allow read, write: if isStaffOfSubcomision(subcomisionId);
    }
    match /subcomisiones/{subcomisionId}/trainings/{trainingId} {
      allow read, write: if isStaffOfSubcomision(subcomisionId);
      match /attendance/{socioId} {
        allow read, write: if isStaffOfSubcomision(subcomisionId);
      }
    }

    // Soporte: staff y dueño del ticket
    match /subcomisiones/{subcomisionId}/supportTickets/{ticketId} {
      allow read: if isSignedIn() && (
        isStaffOfSubcomision(subcomisionId)
        || resource.data.userId == request.auth.uid
      );
      allow create: if isSignedIn() && (isStaffOfSubcomision(subcomisionId) || request.resource.data.userId == request.auth.uid);
      allow update: if isSignedIn() && (isStaffOfSubcomision(subcomisionId) || resource.data.userId == request.auth.uid);
      allow delete: if false;
      match /supportTicketEvents/{eventId} {
        allow read: if isSignedIn() && (isStaffOfSubcomision(subcomisionId) || get(/databases/$(database)/documents/subcomisiones/$(subcomisionId)/supportTickets/$(ticketId)).data.userId == request.auth.uid);
        allow create: if isSignedIn() && (isStaffOfSubcomision(subcomisionId) || get(/databases/$(database)/documents/subcomisiones/$(subcomisionId)/supportTickets/$(ticketId)).data.userId == request.auth.uid);
        allow update, delete: if false;
      }
    }

    // Registro pendiente (solicitudes de alta)
    match /subcomisiones/{subcomisionId}/pendingPlayers/{socioId} {
      allow read: if isStaffOfSubcomision(subcomisionId);
      allow create: if isSignedIn();
      allow update, delete: if isStaffOfSubcomision(subcomisionId);
    }

    match /comercios/{comercioId} {
      allow read: if isSignedIn() && (isGerenteClub() || (request.auth.uid == comercioId));
      allow create, update, delete: if isGerenteClub();
    }

    match /usos_qr/{usoId} {
      allow create: if isSignedIn() && isComercio();
      allow read: if isGerenteClub();
      allow update, delete: if false;
    }

    // --- Viajes (Regatas+) ---
    match /viajes/{viajeId} {
      allow read: if isSignedIn() && (isGerenteClub()
        || (resource.data.subcomisionId != null
            && isAdminSubcomision(resource.data.subcomisionId))
        || (resource.data.subcomisionId != null
            && isEncargadoDeportivo(resource.data.subcomisionId)));
      allow create: if isSignedIn() && request.resource.data.subcomisionId != null
        && (isAdminSubcomision(request.resource.data.subcomisionId) || isGerenteClub());
      allow update: if isSignedIn() && resource.data.subcomisionId != null
        && (isAdminSubcomision(resource.data.subcomisionId) || isGerenteClub());
      allow delete: if isGerenteClub();

      match /pagos/{pagoId} {
        allow read: if isSignedIn() && (
          isGerenteClub()
          || (get(/databases/$(database)/documents/viajes/$(viajeId)).data.subcomisionId != null
              && isAdminSubcomision(get(/databases/$(database)/documents/viajes/$(viajeId)).data.subcomisionId))
          || (get(/databases/$(database)/documents/viajes/$(viajeId)).data.subcomisionId != null
              && isEncargadoDeportivo(get(/databases/$(database)/documents/viajes/$(viajeId)).data.subcomisionId))
          || (resource.data.socioId != null
              && get(/databases/$(database)/documents/viajes/$(viajeId)).data.subcomisionId != null
              && hasSocioLoginFor(get(/databases/$(database)/documents/viajes/$(viajeId)).data.subcomisionId, resource.data.socioId)));
        allow create, update: if isSignedIn() && get(/databases/$(database)/documents/viajes/$(viajeId)).data.subcomisionId != null
          && (isAdminSubcomision(get(/databases/$(database)/documents/viajes/$(viajeId)).data.subcomisionId) || isGerenteClub());
      }

      match /documentacion/{socioId} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/viajes/$(viajeId)).data.subcomisionId != null
          && (isAdminSubcomision(get(/databases/$(database)/documents/viajes/$(viajeId)).data.subcomisionId)
              || isEncargadoDeportivo(get(/databases/$(database)/documents/viajes/$(viajeId)).data.subcomisionId)
              || isGerenteClub());
      }
    }

    // Configuración global de la plataforma (settings, plantillas, etc.)
    match /platformConfig/{docId} {
      allow read: if isSignedIn() && (
        isGerenteClub()
        || docId == 'physicalAssessmentTemplate'
      );
      allow write: if isGerenteClub();
    }

    // Sesiones WhatsApp de Regatas+ (solo backend escribe, no exponer a clientes)
    match /wa_sessions_regatas/{phone} {
      allow read, write: if false;
    }

    // Solicitudes de acceso (registro / alta como socio)
    match /accessRequests/{requestId} {
      allow read: if isSignedIn() && (isGerenteClub() || resource.data.uid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && (isGerenteClub() || resource.data.uid == request.auth.uid);
      allow delete: if isGerenteClub();
    }

    // Index email -> solicitud pendiente (evitar duplicados)
    match /pendingSocioByEmail/{emailKey} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isGerenteClub() || (resource.data.subcomisionId != null && isStaffOfSubcomision(resource.data.subcomisionId));
    }

    // Compat: schools/ (legacy) - mismo modelo que subcomisiones
    match /schools/{schoolId}/trainings/{trainingId} {
      allow read, write: if isStaffOfSubcomision(schoolId);
      match /attendance/{socioId} {
        allow read, write: if isStaffOfSubcomision(schoolId);
      }
    }
    match /schools/{schoolId}/trainingConfig/{docId} {
      allow read, write: if isStaffOfSubcomision(schoolId);
    }
    // schools/players (legacy) - mismo modelo que subcomisiones/socios
    match /schools/{schoolId}/players/{playerId} {
      allow read: if isSignedIn() && (
        isGerenteClub()
        || isStaffOfSubcomision(schoolId)
        || (exists(/databases/$(database)/documents/schools/$(schoolId)/players/$(playerId))
            && get(/databases/$(database)/documents/schools/$(schoolId)/players/$(playerId)).data.get('email', '').lower() == request.auth.token.email.lower())
        || hasSocioLoginFor(schoolId, playerId)
      );
      allow create, update: if isGerenteClub() || isAdminSubcomision(schoolId);
      allow delete: if isGerenteClub() || isAdminSubcomision(schoolId);
    }
    match /schools/{schoolId}/pendingPlayers/{socioId} {
      allow read: if isStaffOfSubcomision(schoolId);
      allow create: if isSignedIn();
      allow update, delete: if isStaffOfSubcomision(schoolId);
    }
    match /schools/{schoolId}/users/{userId} {
      allow read: if isSignedIn() && (isGerenteClub() || isStaffOfSubcomision(schoolId) || request.auth.uid == userId);
      allow create, update: if isGerenteClub() || isAdminSubcomision(schoolId);
      allow delete: if isGerenteClub() || isAdminSubcomision(schoolId);
    }
    match /schools/{schoolId}/supportTickets/{ticketId} {
      allow read: if isSignedIn() && (isStaffOfSubcomision(schoolId) || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (isStaffOfSubcomision(schoolId) || request.resource.data.userId == request.auth.uid);
      allow update: if isSignedIn() && (isStaffOfSubcomision(schoolId) || resource.data.userId == request.auth.uid);
      allow delete: if false;
      match /supportTicketEvents/{eventId} {
        allow read, create: if isSignedIn() && (isStaffOfSubcomision(schoolId) || get(/databases/$(database)/documents/schools/$(schoolId)/supportTickets/$(ticketId)).data.userId == request.auth.uid);
        allow update, delete: if false;
      }
    }

    // Posts / Notas (colección top-level, subcomisionId en cada doc)
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.subcomisionId != null && (isGerenteClub() || isStaffOfSubcomision(request.resource.data.subcomisionId) || isEditorOrViewer(request.resource.data.subcomisionId));
      allow update, delete: if isSignedIn() && resource.data.subcomisionId != null && (isGerenteClub() || isStaffOfSubcomision(resource.data.subcomisionId) || isEditorOrViewer(resource.data.subcomisionId));
    }
  }
}
