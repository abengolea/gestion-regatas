# Firebase - app "escuelariver" (proyecto lexflow-consultas)
# Obtener desde: Firebase Console → lexflow-consultas → Configuración (engranaje) → Tus apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=lexflow-consultas.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=lexflow-consultas
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=lexflow-consultas.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=664196918383
NEXT_PUBLIC_FIREBASE_APP_ID=1:664196918383:web:e58546257d0d98e9fdf19a

# Genkit / Google AI (Gemini)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# URL base de la app (localhost en desarrollo, URL real en producción)
NEXT_PUBLIC_APP_URL=http://localhost:9003

# Mercado Pago OAuth
# MERCADOPAGO_CLIENT_ID=
# MERCADOPAGO_CLIENT_SECRET=

# WhatsApp (opcional)
# PHONE_NUMBER_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# WHATSAPP_TOKEN=

# NotificasHub (opcional)
# NOTIFICASHUB_PROJECT_ID=
# NOTIFICASHUB_CLIENT_EMAIL=
# NOTIFICASHUB_PRIVATE_KEY=

# Cuenta de servicio (para firebase-admin: scripts, API routes)
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# QR Regatas+ (JWT para validación de socios en comercios)
# Mínimo 32 caracteres para HS256
QR_JWT_SECRET=cambiar_por_secreto_seguro_de_32_chars_minimo

# Club
NEXT_PUBLIC_CLUB_NOMBRE="Club de Regatas San Nicolás"
NEXT_PUBLIC_CLUB_SLUG="regatas-san-nicolas"

# Banco del club (para transferencias)
CLUB_CBU=0000000000000000000000
CLUB_ALIAS=REGATAS.SN
CLUB_BANCO=Santander
NEXT_PUBLIC_CLUB_WA_NUMBER=5491112345678

# NotificasHub
NOTIFICASHUB_INTERNAL_SECRET=regatas_internal_2026
NOTIFICASHUB_URL=https://notificashub.com
NEXT_PUBLIC_NOTIFICASHUB_ACTIVO=true

# NotificasHub Firestore (proyecto del hub — distinto a Regatas+)
# NOTIFICASHUB_FIREBASE_PROJECT_ID=notificashub-prod
# NOTIFICASHUB_FIREBASE_CLIENT_EMAIL=...
# NOTIFICASHUB_FIREBASE_PRIVATE_KEY=...

# Mercado Pago — vacío hasta tener cuenta
# MP_ACCESS_TOKEN=
# MP_WEBHOOK_SECRET=
MP_ENABLED=false

# Santander Pay — vacío hasta tener API
# SANTANDER_PAY_API_KEY=
SANTANDER_PAY_ENABLED=false

# Viajes - Notificaciones
# SENDGRID_API_KEY=SG....

# WhatsApp del club (número sin +, ej: 5491112345678)
# NEXT_PUBLIC_CLUB_WA_NUMBER=5491112345678  # ya definido arriba en Club
