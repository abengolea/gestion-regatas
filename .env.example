# Firebase - Proyecto BasquetAdmin (basquetadmin)
# Obtener desde: Firebase Console → basquetadmin → Configuración (engranaje) → Tus apps
# Si no hay app web, agregar una (icono </>)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=basquetadmin.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=basquetadmin
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=basquetadmin.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# URL base de la app (localhost en desarrollo, URL real en producción)
NEXT_PUBLIC_APP_URL=http://localhost:9003

# Cuenta de servicio (para firebase-admin: scripts, API routes)
# Descargar desde: Firebase Console → Configuración → Cuentas de servicio
# Opción 1: ruta al JSON
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# Opción 2: poner service-account.json en la raíz del proyecto

# Mercado Pago (opcional, si usás pagos)
# MERCADOPAGO_CLIENT_ID=
# MERCADOPAGO_CLIENT_SECRET=
# MERCADOPAGO_USE_TEST_TOKENS=true
